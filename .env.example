# ===== CORE =====
NODE_ENV=development
PORT=3001
WEB_PORT=3000
LOG_LEVEL=info

# ===== DATABASE =====
DATABASE_URL=postgresql://ouro:ouro_pass@localhost:5432/ouro
REDIS_URL=redis://localhost:6379

# ===== AI PROVIDERS =====
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Models
PRIMARY_LLM_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small

# ===== STORAGE =====
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ouro-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ===== EVOLUTION ENGINE =====
EVOLUTION_CYCLE_INTERVAL=10
EVOLUTION_MIN_SAMPLES=5
INTENT_CONFIDENCE_THRESHOLD=0.7
MAX_CLARIFICATION_QUESTIONS=1

# ===== EXECUTION =====
MAX_PARALLEL_STEPS=4
STEP_TIMEOUT_MS=120000
PLAN_TIMEOUT_MS=30000
