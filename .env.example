# Ouro Configuration
# Copy this to .env and set values

# AI Provider (optional — system works without it using mock provider)
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql://ouro:ouro_pass@localhost:5432/ouro

# Redis (optional — falls back to in-memory cache)
REDIS_URL=redis://localhost:6379

# S3 Storage (optional — for file/media storage)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ouro-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Server
PORT=3001
CORS_ORIGIN=*
NODE_ENV=development
